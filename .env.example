# Telegram Bot Configuration
# Get your bot token from BotFather on Telegram: https://t.me/botfather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# FreeStuff API Configuration
# Get your public key from FreeStuff Dashboard: https://dashboard.freestuffbot.xyz
FREESTUFF_PUBLIC_KEY=your_freestuff_public_key_here

# FreeStuff REST API key used for manual /product requests
FREESTUFF_API_KEY=your_freestuff_api_key_here

# Optional JSON config for Telegram channels, filters, and enable/disable state
# Example:
# TELEGRAM_CHANNELS={"de":{"chat":"@freestuff_german","preferredCurrency":"eur","preferredLanguage":"de-DE","enabled":false}}

# Optional Discord webhook for error alerts when Telegram API returns non-ok responses
DISCORD_WEBHOOK_URL=

